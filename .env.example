# InvestorFrame Configuration
# Copy this file to .env and fill in your API keys

# Required: FRED API key (free at https://fred.stlouisfed.org/docs/api/api_key.html)
INVESTORFRAME_FRED_API_KEY=your_fred_api_key_here

# Required: NewsAPI key (free at https://newsapi.org/register)
INVESTORFRAME_NEWSAPI_KEY=your_newsapi_key_here

# Optional: OpenAI API key (for LLM-enhanced analysis)
INVESTORFRAME_OPENAI_API_KEY=your_openai_api_key_here
INVESTORFRAME_OPENAI_MODEL=gpt-4o-mini

# Pipeline Settings
INVESTORFRAME_ENABLE_LLM=false
INVESTORFRAME_LOOKBACK_DAYS=7
INVESTORFRAME_MAX_EVENTS=100
INVESTORFRAME_CONFIDENCE_FLOOR=0.3

# Database
INVESTORFRAME_DB_URL=sqlite:///investorframe.db
